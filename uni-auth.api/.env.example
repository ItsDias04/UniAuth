# Security email delivery (SMTP)
SMTP_EMAIL=your-email@gmail.com
SMTP_APP_PASSWORD=your-16-char-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=UniAuth

# Security monitoring notifications (comma-separated)
SECURITY_MONITOR_NOTIFICATION_EMAILS=dias.temerbekov.it@gmail.com,dias.temerbekov.it@gmail.com

# IDS/IPS toggles
SECURITY_MONITOR_PREVENT_INTRUSIONS=true
SECURITY_MONITOR_BLOCK_ON_SIGNATURE=true

# Brute-force behavior
SECURITY_MONITOR_AUTH_FAILURE_WINDOW_SECONDS=600
SECURITY_MONITOR_AUTH_FAILURE_SUSPICIOUS_THRESHOLD=5
SECURITY_MONITOR_AUTH_FAILURE_BLOCK_THRESHOLD=8
SECURITY_MONITOR_AUTH_BLOCK_MINUTES=30

# Monitoring payload controls
SECURITY_MONITOR_MAX_SERIALIZED_LENGTH=12000
SECURITY_MONITOR_ALERT_COOLDOWN_SECONDS=120

# Dedicated security officer account (isolated from regular IAM login)
SECURITY_OFFICER_LOGIN=security.officer
SECURITY_OFFICER_PASSWORD=ChangeThisSecurityOfficerPassword
SECURITY_OFFICER_JWT_SECRET=ChangeThisSeparateOfficerJwtSecret
SECURITY_OFFICER_JWT_TTL_SECONDS=3600
